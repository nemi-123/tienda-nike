				{
					"name": "Logout - Cerrar sesión",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"description": "Token JWT obtenido del login"
							}
						],
						"url": {
							"raw": "{{base_url_usuarios}}/api/v1/auth/logout",
							"host": ["{{base_url_usuarios}}"],
							"path": ["api", "v1", "auth", "logout"]
						},
						"description": "Cierra la sesión invalidando el token JWT actual.\n\nEl token se agrega a una blacklist en memoria del servidor.\nDespués de este paso, el token ya no será aceptado por ningún endpoint protegido.\n\n**Prerequisito:** Haber ejecutado un Login primero para tener un token válido."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code es 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Respuesta contiene mensaje de confirmación', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData.message).to.include('Sesión cerrada');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Verificar token invalidado (401 post-logout)",
