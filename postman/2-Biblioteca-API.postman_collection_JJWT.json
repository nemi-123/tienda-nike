			"item": [
				{
					"name": "Register - Registrar nuevo usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nombre\": \"Test\",\n    \"apellido\": \"Usuario\",\n    \"email\": \"test@postman.cl\",\n    \"password\": \"Test@2026\"\n}"
						},
						"url": {
							"raw": "{{base_url_usuarios}}/api/v1/auth/register",
							"host": ["{{base_url_usuarios}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Registra un nuevo usuario con rol Cliente.\n\nNo requiere autenticación.\n\nValidaciones:\n- nombre: obligatorio, máx 150 caracteres\n- apellido: obligatorio, máx 150 caracteres\n- email: obligatorio, formato email válido\n- password: obligatorio, entre 6 y 50 caracteres"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code es 201 Created', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Respuesta contiene datos del usuario', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('nombre');",
									"    pm.expect(jsonData).to.have.property('apellido');",
									"    pm.expect(jsonData).to.have.property('email');",
									"    pm.expect(jsonData).to.have.property('rol');",
									"    pm.expect(jsonData.rol).to.eql('Cliente');",
									"    pm.expect(jsonData).to.have.property('activo');",
									"    pm.expect(jsonData.activo).to.eql(true);",
									"});",
									"",
									"pm.test('El rol asignado es Cliente', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.rol).to.eql('Cliente');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Login - Iniciar sesión (Administrador)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"ana@administrador.cl\",\n    \"password\": \"Biblio@2026\"\n}"
						},
						"url": {
							"raw": "{{base_url_usuarios}}/api/v1/auth/login",
							"host": ["{{base_url_usuarios}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Inicia sesión con credenciales de Administrador.\n\nEl token JWT se guarda automáticamente en la variable `jwt_token` para uso en las siguientes peticiones.\n\nCredenciales: ana@administrador.cl / Biblio@2026"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code es 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Respuesta contiene token JWT', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.expect(jsonData.token.length).to.be.greaterThan(0);",
									"});",
									"",
									"pm.test('Respuesta contiene datos del usuario', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('email');",
									"    pm.expect(jsonData).to.have.property('nombre');",
									"    pm.expect(jsonData).to.have.property('rol');",
									"    pm.expect(jsonData).to.have.property('expiresIn');",
									"});",
									"",
									"pm.test('Token type es Bearer', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('tokenType');",
									"    pm.expect(jsonData.tokenType).to.eql('Bearer');",
									"});",
									"",
									"// Guardar token automáticamente para las siguientes peticiones",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set('jwt_token', jsonData.token);",
									"    console.log('Token JWT guardado exitosamente');",
									"}"
								]
							}
						}
					]
				},
